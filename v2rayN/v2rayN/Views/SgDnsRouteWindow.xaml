<Window
    x:Class="v2rayN.Views.SgDnsRouteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="SG Client — Маршрут DNS"
    Width="690"
    Height="470"
    MinWidth="620"
    MinHeight="430"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    Icon="/Resources/v2rayN.ico"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="7" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DnsChoice" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ChoiceBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="RadioDot" Width="20" Height="20" VerticalAlignment="Top" Margin="0,1,0,0" Background="Transparent" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="2" CornerRadius="10">
                                    <Ellipse x:Name="RadioFill" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource SgAccentBrush}" Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Grid.Column="1" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="Background" Value="{DynamicResource SgHoverBrush}" />
                                <Setter TargetName="ChoiceBorder" Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="Background" Value="{DynamicResource SgSelectedBrush}" />
                                <Setter TargetName="ChoiceBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                                <Setter TargetName="RadioDot" Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
                                <Setter TargetName="RadioFill" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18,0,9,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border Width="38" Height="38" Background="{DynamicResource SgAccentSoftBrush}" BorderBrush="{DynamicResource SgAccentBorderBrush}" BorderThickness="1" CornerRadius="10">
                            <materialDesign:PackIcon Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SgAccentBrush}" Kind="Dns" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" FontWeight="SemiBold" Text="Маршрут DNS" />
                            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Выберите явно — скрытого переключателя больше нет" />
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnClose" Grid.Column="1" shell:WindowChrome.IsHitTestVisibleInChrome="True" Width="38" Height="38" Background="Transparent" BorderThickness="1" Foreground="{DynamicResource SgMutedBrush}" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Закрыть" BorderBrush="{DynamicResource SgButtonOutlineBrush}">
                        <materialDesign:PackIcon Width="19" Height="19" Kind="Close" />
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="18,16,18,10">
                <TextBlock FontSize="13" Foreground="{DynamicResource SgMutedBrush}" Text="DNS влияет на то, где разрешаются доменные имена. Безопасное значение после установки и восстановления копии — через VPN." TextWrapping="Wrap" />

                <RadioButton x:Name="rbDnsViaVpn" GroupName="DnsRoute" Margin="0,16,0,10" Style="{StaticResource DnsChoice}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="DNS через VPN — рекомендуется" />
                        <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Запросы DNS обслуживаются согласованно с TUN и не отправляются провайдеру напрямую." TextWrapping="Wrap" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="rbDnsDirect" GroupName="DnsRoute" Style="{StaticResource DnsChoice}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SgWarningBrush}" Text="DNS напрямую — только для диагностики" />
                        <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Системный DNS может раскрывать запрашиваемые домены вне VPN и давать другой результат маршрутизации. Включайте только осознанно." TextWrapping="Wrap" />
                    </StackPanel>
                </RadioButton>

                <Border x:Name="directWarning" Margin="0,2,0,0" Padding="12,9" Background="{DynamicResource SgWarningSoftBrush}" BorderBrush="{DynamicResource SgWarningBrush}" BorderThickness="1" CornerRadius="9" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="{DynamicResource SgTextBrush}" Text="После применения активный TUN будет переподключён. Фактические VPN / Direct соединения видны в окне «Маршруты»." TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Padding="14,10" Background="{DynamicResource SgSurfaceBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,15,15">
                <Grid>
                    <TextBlock x:Name="txtCurrent" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Текущее значение: —" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button x:Name="btnCancel" Width="112" Height="38" Margin="0,0,8,0" Content="Отмена" />
                        <Button x:Name="btnApply" Width="138" Height="38" Content="Применить" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
