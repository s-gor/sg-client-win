<reactiveui:ReactiveUserControl
    x:Class="v2rayN.Views.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:v2rayN.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2009"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:enums="clr-namespace:ServiceLib.Enums;assembly=ServiceLib"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:reactiveui="http://reactiveui.net"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    d:DesignHeight="760"
    d:DesignWidth="430"
    x:TypeArguments="vms:ProfilesViewModel"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:ProfileCountryFlagConverter x:Key="ProfileCountryFlagConverter" />
        <converters:ProfileDisplayRemarksConverter x:Key="ProfileDisplayRemarksConverter" />

        <DataTemplate x:Key="BrowserOptionTemplate">
            <TextBlock VerticalAlignment="Center" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <Style x:Key="ProfileSearchTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="36,0,36,0" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SgAccentBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border
                            x:Name="SearchBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalAlignment="Center"
                                VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource SgTrafficDownloadBrush}" />
                                <Setter TargetName="SearchBorder" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}" />
                                <Setter TargetName="SearchBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileComboBoxItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                ContentSource="Content"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgAccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SgAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="11,0,34,0" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ProfileComboBoxItem}" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="MaxDropDownHeight" Value="360" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="False" />
        </Style>

        <Style x:Key="SgProfileItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ProfileItem_PreviewMouseRightButtonDown" />
            <EventSetter Event="MouseDoubleClick" Handler="LstProfiles_MouseDoubleClick" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="ItemBorder"
                            MinHeight="94"
                            Padding="12,10"
                            Background="{DynamicResource SgSurfaceSoftBrush}"
                            BorderBrush="{DynamicResource SgBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid>
                                <Border
                                    x:Name="ActiveLine"
                                    Width="3"
                                    Margin="-10,-3,0,-3"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    CornerRadius="3" />
                                <ContentPresenter />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgSelectedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgSuccessSoftBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SgSuccessBrush}" />
                                <Setter TargetName="ActiveLine" Property="Background" Value="{DynamicResource SgSuccessBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileToolButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{DynamicResource SgNeutralActionTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgNeutralActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgNeutralActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ToolBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="{DynamicResource SgNeutralActionHoverBrush}" />
                                <Setter TargetName="ToolBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="{DynamicResource SgNeutralActionPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToolBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <TextBox
                    x:Name="txtProfileSearch"
                    Style="{StaticResource ProfileSearchTextBox}"
                    TextChanged="ProfileSearch_TextChanged" />
                <materialDesign:PackIcon
                    Width="17"
                    Height="17"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource SgMutedBrush}"
                    IsHitTestVisible="False"
                    Kind="Magnify" />
                <TextBlock
                    Margin="36,0,38,0"
                    VerticalAlignment="Center"
                    FontSize="11.5"
                    Foreground="{DynamicResource SgMutedBrush}"
                    IsHitTestVisible="False"
                    Text="Поиск по имени, адресу или источнику…"
                    TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtProfileSearch}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button
                    Width="28"
                    Height="28"
                    Margin="0,0,5,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ClearProfileSearch_Click"
                    Foreground="{DynamicResource SgMutedBrush}"
                    ToolTip="Очистить поиск">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SgWindowButtonBase}" TargetType="{x:Type Button}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtProfileSearch}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <materialDesign:PackIcon Width="15" Height="15" Kind="Close" />
                </Button>
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox
                    x:Name="cmbSubscriptionFilter"
                    Grid.Column="0"
                    Style="{StaticResource ProfileComboBox}"
                    DisplayMemberPath="Label"
                    TextSearch.TextPath="Label"
                    PreviewMouseLeftButtonDown="ProfileCombo_PreviewMouseLeftButtonDown"
                    PreviewKeyDown="ProfileCombo_PreviewKeyDown"
                    SelectedValuePath="Key"
                    SelectionChanged="ProfileFilter_SelectionChanged"
                    ToolTip="Фильтр по подписке или источнику" />
                <ComboBox
                    x:Name="cmbProtocolFilter"
                    Grid.Column="2"
                    Style="{StaticResource ProfileComboBox}"
                    DisplayMemberPath="Label"
                    TextSearch.TextPath="Label"
                    PreviewMouseLeftButtonDown="ProfileCombo_PreviewMouseLeftButtonDown"
                    PreviewKeyDown="ProfileCombo_PreviewKeyDown"
                    SelectedValuePath="Key"
                    SelectionChanged="ProfileFilter_SelectionChanged"
                    ToolTip="Фильтр по протоколу" />
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox
                    x:Name="cmbCountryFilter"
                    Grid.Column="0"
                    Style="{StaticResource ProfileComboBox}"
                    TextSearch.TextPath="Label"
                    PreviewMouseLeftButtonDown="ProfileCombo_PreviewMouseLeftButtonDown"
                    PreviewKeyDown="ProfileCombo_PreviewKeyDown"
                    SelectedValuePath="Key"
                    SelectionChanged="ProfileFilter_SelectionChanged"
                    ToolTip="Фильтр по стране">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="17" Margin="0,0,8,0" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="3">
                                    <Grid>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="{Binding CountryCode}" />
                                        <Image Source="{Binding CountryFlagUri}" Stretch="Uniform" SnapsToDevicePixels="True" />
                                    </Grid>
                                </Border>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox
                    x:Name="cmbProfileSort"
                    Grid.Column="2"
                    Style="{StaticResource ProfileComboBox}"
                    DisplayMemberPath="Label"
                    TextSearch.TextPath="Label"
                    PreviewMouseLeftButtonDown="ProfileCombo_PreviewMouseLeftButtonDown"
                    PreviewKeyDown="ProfileCombo_PreviewKeyDown"
                    SelectedValuePath="Key"
                    SelectionChanged="ProfileSort_Changed"
                    ToolTip="Сортировка профилей" />
            </Grid>
            <CheckBox
                x:Name="chkExcludeCountry"
                Margin="2,7,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Checked="CountryExclude_Changed"
                Content="Исключить выбранную страну"
                Foreground="{DynamicResource SgMutedBrush}"
                IsEnabled="False"
                Unchecked="CountryExclude_Changed" />
            <TextBlock
                x:Name="txtProfileCount"
                Margin="0,7,2,0"
                HorizontalAlignment="Right"
                FontSize="9.5"
                Foreground="{DynamicResource SgMutedBrush}"
                Text="Показано: 0" />
        </StackPanel>

        <ListBox
            x:Name="lstProfiles"
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource SgProfileItem}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Single"
            IsEnabled="{Binding TunBusy, Converter={StaticResource InverseBooleanConverter}}"
            VirtualizingPanel.CacheLength="2"
            VirtualizingPanel.CacheLengthUnit="Page"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.ScrollUnit="Item"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.InputBindings>
                <KeyBinding Command="ApplicationCommands.NotACommand" Gesture="Ctrl+C" />
                <KeyBinding Command="ApplicationCommands.NotACommand" Gesture="Ctrl+V" />
                <KeyBinding Command="ApplicationCommands.NotACommand" Gesture="Delete" />
                <KeyBinding Command="ApplicationCommands.NotACommand" Gesture="Enter" />
            </ListBox.InputBindings>
            <ListBox.ContextMenu>
                <ContextMenu Style="{StaticResource DefContextMenu}">
                    <MenuItem x:Name="menuSetDefaultServer" Header="Выбрать профиль" InputGestureText="Enter" Visibility="Collapsed" />
                    <MenuItem x:Name="menuEditServer" Header="Изменить" Visibility="Collapsed" />
                    <MenuItem x:Name="menuRemoveServer" Header="Удалить" InputGestureText="Delete" />
                    <Separator />
                    <MenuItem x:Name="menuRealPingServer" Header="Проверить задержку" InputGestureText="Ctrl+R" />
                    <MenuItem x:Name="menuTcpingServer" Header="Проверить TCP" InputGestureText="Ctrl+O" />
                    <Separator />
                    <MenuItem x:Name="menuCopyServer" Header="Создать копию" Visibility="Collapsed" />
                    <MenuItem x:Name="menuExport2ShareUrl" Header="Копировать ссылку" InputGestureText="Ctrl+C" />
                    <MenuItem x:Name="menuShareServer" Header="Показать QR-код" Visibility="Collapsed" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="94" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="40" Height="30" Margin="0,0,11,0" VerticalAlignment="Center" ToolTip="{Binding CountryToolTip}">
                            <Border
                                Width="32"
                                Height="22"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{DynamicResource SgInputBrush}"
                                BorderBrush="{DynamicResource SgBorderStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource SgMutedBrush}"
                                        Text="{Binding CountryBadge}" />
                                    <Image
                                        Stretch="Uniform"
                                        SnapsToDevicePixels="True">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource ProfileCountryFlagConverter}">
                                                <Binding Path="CountryCode" />
                                                <Binding Path="Remarks" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                </Grid>
                            </Border>
                            <Ellipse
                                Width="10"
                                Height="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Stroke="{DynamicResource SgSurfaceSoftBrush}"
                                StrokeThickness="2">
                                <Ellipse.Style>
                                    <Style TargetType="{x:Type Ellipse}">
                                        <Setter Property="Fill" Value="{DynamicResource SgOffBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SgSuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock
                                MaxHeight="42"
                                TextWrapping="Wrap"
                                TextTrimming="CharacterEllipsis"
                                FontSize="14.5"
                                LineHeight="20"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SgTextBrush}"
                                ToolTip="{Binding CountryToolTip}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource ProfileDisplayRemarksConverter}">
                                        <Binding Path="CountryCode" />
                                        <Binding Path="Remarks" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock
                                Margin="0,3,0,0"
                                TextTrimming="CharacterEllipsis"
                                FontSize="10.8"
                                Foreground="{DynamicResource SgMutedBrush}"
                                Text="{Binding ProtocolDisplay}" />
                            <TextBlock
                                Margin="0,3,0,0"
                                TextTrimming="CharacterEllipsis"
                                FontSize="9.5"
                                Foreground="{DynamicResource SgMutedBrush}"
                                Text="{Binding SourceDisplay}"
                                ToolTip="{Binding SourceDisplay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SgTextBrush}"
                                Text="{Binding DelayVal}" />
                            <TextBlock Margin="0,5,0,0" HorizontalAlignment="Right" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="ВЫБРАН">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsActive}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.TunEnabled, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False" />
                                                    <Condition Binding="{Binding DataContext.TunBusy, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0" HorizontalAlignment="Right" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource SgSuccessBrush}" Text="ИСПОЛЬЗУЕТСЯ">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsActive}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.TunEnabled, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.TunBusy, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0" HorizontalAlignment="Right" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource SgWarningBrush}" Text="ПЕРЕКЛЮЧЕНИЕ">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsActive}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.TunUiState, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="{x:Static enums:ETunUiState.Switching}" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <Border
                Margin="0,0,0,8"
                Padding="10,8"
                Background="{DynamicResource SgSurfaceSoftBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="1"
                CornerRadius="9"
                Visibility="{Binding LatencyTestPanelVisible, Converter={StaticResource BoolToVisConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="84" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock
                            FontSize="10.5"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SgTextBrush}"
                            Text="{Binding LatencyTestStatus}" />
                        <ProgressBar
                            Height="7"
                            Margin="0,6,0,0"
                            Maximum="100"
                            Value="{Binding LatencyTestProgress}" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Height="30"
                        Click="CancelLatencyTest_Click"
                        Content="Остановить"
                        IsEnabled="{Binding LatencyTestRunning}"
                        Style="{StaticResource ProfileToolButton}" />
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnActivateProfile"
                    Grid.Column="0"
                    Click="ActivateSelectedProfile_Click"
                    IsEnabled="False"
                    Style="{StaticResource ProfileToolButton}"
                    ToolTip="Подключить или переключить на выделенный профиль">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="14" Height="14" Margin="0,0,6,0" Kind="SwapHorizontal" />
                        <TextBlock x:Name="txtActivateProfileButton" VerticalAlignment="Center" FontSize="10" Text="Переключить" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="btnPingVisible"
                    Grid.Column="2"
                    Click="PingVisible_Click"
                    IsEnabled="{Binding LatencyTestRunning, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource ProfileToolButton}"
                    ToolTip="Проверить задержку только показанных поиском и фильтрами профилей">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="14" Height="14" Margin="0,0,6,0" Kind="FilterOutline" />
                        <TextBlock VerticalAlignment="Center" FontSize="10" Text="Тест списка" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="btnPingAll"
                    Grid.Column="4"
                    Click="PingAll_Click"
                    IsEnabled="{Binding LatencyTestRunning, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource ProfileToolButton}"
                    ToolTip="Проверить задержку всех профилей. Большие списки обрабатываются ограниченными пакетами">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="14" Height="14" Margin="0,0,6,0" Kind="LightningBolt" />
                        <TextBlock VerticalAlignment="Center" FontSize="10" Text="Тест всех" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="btnRemoveServer"
                    Grid.Column="6"
                    Foreground="{DynamicResource SgErrorBrush}"
                    IsEnabled="{Binding TunBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource ProfileToolButton}"
                    ToolTip="Удалить выбранный профиль">
                    <materialDesign:PackIcon Width="17" Height="17" Kind="Delete" />
                </Button>
            </Grid>
        </StackPanel>

        <!-- Hidden compatibility controls keep the mature v2rayN view-model wiring intact. -->
        <Grid Visibility="Collapsed">
            <TextBox x:Name="txtServerFilter" />
            <ListBox x:Name="lstGroup" />
            <Button x:Name="btnAddSub" />
            <Button x:Name="btnEditSub" />
            <Button x:Name="menuMixedTestServer" />
        </Grid>
    </Grid>
</reactiveui:ReactiveUserControl>
