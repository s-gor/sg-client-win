<Window
    x:Class="v2rayN.Views.SgSubscriptionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Подписки SG Client"
    Width="974"
    Height="714"
    MinWidth="860"
    MinHeight="620"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="7" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SubscriptionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="PrimaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="38" /><Setter Property="MinWidth" Value="124" /><Setter Property="Padding" Value="16,5" />
            <Setter Property="Background" Value="{DynamicResource SgAccentBrush}" /><Setter Property="Foreground" Value="{DynamicResource SgOnButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13.5" />
        </Style>
        <Style x:Key="SecondaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="34" /><Setter Property="MinWidth" Value="96" /><Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" /><Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SmallButton" BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
            <Setter Property="Height" Value="30" /><Setter Property="MinWidth" Value="72" /><Setter Property="Padding" Value="10,3" /><Setter Property="FontSize" Value="10" />
        </Style>
        <Style x:Key="DangerButton" BasedOn="{StaticResource SmallButton}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource SgErrorBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource SgErrorBrush}" />
        </Style>
        <Style x:Key="InputBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}" TargetType="TextBox">
            <Setter Property="Height" Value="48" /><Setter Property="Padding" Value="12,0" /><Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" /><Setter Property="FontSize" Value="11.5" />
        </Style>
        <Style x:Key="SubscriptionListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,0,9" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><ContentPresenter /></ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="64" /><RowDefinition Height="*" /></Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="20,0,10,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Подписки" />
                        <TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Управление источниками профилей и безопасное обновление" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="96" Height="36" Content="Справка" Click="Help_Click" Style="{StaticResource SecondaryButton}" />
                        <Button Width="96" Height="36" Margin="8,0,0,0" Content="Закрыть" Click="Close_Click" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="contentRoot" Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions><ColumnDefinition Width="330" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SubscriptionCard}">
                    <StackPanel>
                        <TextBlock x:Name="txtEditorTitle" FontSize="17" FontWeight="SemiBold" Text="Новая подписка" />
                        <TextBlock Margin="0,6,0,16" FontSize="10.5" LineHeight="16" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Добавьте URL подписки. При ошибке обновления SG Client сохранит последний рабочий набор профилей." />

                        <TextBlock Margin="0,0,0,6" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Название" />
                        <TextBox x:Name="txtSubscriptionName" Style="{StaticResource InputBox}" materialDesign:HintAssist.Hint="Например: Основной сервер" />

                        <TextBlock Margin="0,16,0,6" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="URL подписки" />
                        <TextBox x:Name="txtSubscriptionUrl" Height="92" Padding="12,10" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Foreground="{DynamicResource SgTextBrush}" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" />

                        <CheckBox x:Name="chkSubscriptionEnabled" Margin="0,15,0,0" IsChecked="True" Content="Подписка включена" Foreground="{DynamicResource SgTextBrush}" />

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <Button x:Name="btnSaveSubscription" Content="Сохранить" Click="SaveSubscription_Click" Style="{StaticResource PrimaryButton}" />
                            <Button x:Name="btnCancelEdit" Margin="10,0,0,0" Content="Отмена" Click="CancelEdit_Click" Style="{StaticResource SecondaryButton}" Visibility="Collapsed" />
                        </StackPanel>

                        <Border Margin="0,22,0,0" Padding="13" Background="{DynamicResource SgAccentSoftBrush}" BorderBrush="{DynamicResource SgAccentBorderBrush}" BorderThickness="1" CornerRadius="11">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="БЕЗОПАСНОЕ ОБНОВЛЕНИЕ" />
                                <TextBlock Margin="0,7,0,0" FontSize="10" LineHeight="16" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Сначала загружается и проверяется новый список. Если он пуст или повреждён, прежние рабочие профили восстанавливаются автоматически." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

                    <Border Style="{StaticResource SubscriptionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Сохранённые подписки" />
                                <TextBlock x:Name="txtSubscriptionCount" Margin="0,5,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="0 подписок" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Обновить все напрямую" Click="UpdateAllDirect_Click" Style="{StaticResource SecondaryButton}" />
                                <Button Grid.Column="2" Content="Обновить все через VPN" Click="UpdateAllVpn_Click" Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Margin="0,12,0,12" Padding="14,10" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Ellipse x:Name="statusDot" Width="8" Height="8" Margin="0,1,10,0" VerticalAlignment="Top" Fill="{DynamicResource SgAccentBrush}" />
                            <TextBlock x:Name="txtStatus" Grid.Column="1" FontSize="10.5" LineHeight="16" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Готово к работе." />
                            <ProgressBar x:Name="progressUpdate" Grid.Column="2" Width="96" Height="4" Margin="12,6,0,0" IsIndeterminate="True" Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <TextBlock x:Name="txtEmpty" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SgMutedBrush}" Text="Подписок пока нет. Добавьте первую слева." />
                        <ListBox x:Name="lstSubscriptions" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource SubscriptionListItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,14" Background="{DynamicResource SgSurfaceBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="13">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,1,9,0" VerticalAlignment="Center" Fill="{Binding StateBrush}" />
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" />
                                                </StackPanel>
                                                <TextBlock Margin="17,5,0,0" MaxWidth="470" FontSize="9.8" Foreground="{DynamicResource SgMutedBrush}" Text="{Binding UrlDisplay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Url}" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="9,3" VerticalAlignment="Top" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="9">
                                                <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{Binding StateBrush}" Text="{Binding StateText}" />
                                            </Border>

                                            <StackPanel Grid.Row="1" Margin="17,12,0,0" Orientation="Horizontal">
                                                <TextBlock FontSize="10" Foreground="{DynamicResource SgTextBrush}" Text="{Binding ProfileCountText}" />
                                                <TextBlock Margin="16,0,0,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="{Binding LastUpdateText}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="17,13,0,0" Orientation="Horizontal">
                                                <Button Tag="{Binding Id}" Content="Напрямую" Click="UpdateDirect_Click" Style="{StaticResource SmallButton}" />
                                                <Button Tag="{Binding Id}" Margin="7,0,0,0" Content="Через VPN" Click="UpdateVpn_Click" Style="{StaticResource SmallButton}" />
                                                <Button Tag="{Binding Id}" Margin="18,0,0,0" Content="Изменить" Click="EditSubscription_Click" Style="{StaticResource SmallButton}" />
                                                <Button Tag="{Binding Id}" Margin="7,0,0,0" Content="Удалить" Click="DeleteSubscription_Click" Style="{StaticResource DangerButton}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="confirmationOverlay" Grid.RowSpan="2" Background="#B8000000" Visibility="Collapsed">
                <Border Width="440" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource SgSurfaceBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="15">
                    <StackPanel>
                        <TextBlock x:Name="txtConfirmTitle" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock x:Name="txtConfirmBody" Margin="0,9,0,0" FontSize="11" LineHeight="17" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" />
                        <StackPanel Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Content="Отмена" Click="CancelConfirmation_Click" Style="{StaticResource SecondaryButton}" />
                            <Button x:Name="btnConfirmAction" Margin="10,0,0,0" Content="Продолжить" Click="ConfirmAction_Click" Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
