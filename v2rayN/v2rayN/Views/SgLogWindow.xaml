<Window
    x:Class="v2rayN.Views.SgLogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="SG Client — Журнал"
    Width="1220"
    Height="820"
    MinWidth="760"
    MinHeight="480"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="7"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="LogHeaderButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="13,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border
        Background="{DynamicResource SgBackgroundBrush}"
        BorderBrush="{DynamicResource SgBorderStrongBrush}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="68" />
                <RowDefinition Height="*" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="20,0,10,0"
                Background="{DynamicResource SgHeaderBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="15,15,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="19" FontWeight="SemiBold" Text="Журнал работы" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontSize="10.5"
                            Foreground="{DynamicResource SgMutedBrush}"
                            Text="Полное изменяемое окно · прокрутка · автопрокрутка · фильтр" />
                    </StackPanel>
                    <Button
                        x:Name="btnSave"
                        Grid.Column="1"
                        Content="Сохранить"
                        Style="{StaticResource LogHeaderButton}" />
                    <Button
                        x:Name="btnOpenFolder"
                        Grid.Column="2"
                        Content="Папка журналов"
                        Style="{StaticResource LogHeaderButton}" />
                    <Button
                        x:Name="btnWindowMinimize"
                        Grid.Column="3"
                        Width="38"
                        Height="38"
                        MinWidth="38"
                        Margin="0"
                        Background="Transparent"
                        BorderThickness="1"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Свернуть" BorderBrush="{DynamicResource SgButtonOutlineBrush}">
                        <materialDesign:PackIcon Width="19" Height="19" Kind="Minimize" />
                    </Button>
                    <Button
                        x:Name="btnWindowMaximize"
                        Grid.Column="4"
                        Width="38"
                        Height="38"
                        MinWidth="38"
                        Margin="0"
                        Background="Transparent"
                        BorderThickness="1"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Развернуть" BorderBrush="{DynamicResource SgButtonOutlineBrush}">
                        <materialDesign:PackIcon x:Name="icoWindowMaximize" Width="18" Height="18" Kind="WindowMaximize" />
                    </Button>
                    <Button
                        x:Name="btnWindowClose"
                        Grid.Column="5"
                        Width="38"
                        Height="38"
                        MinWidth="38"
                        Margin="0"
                        Background="Transparent"
                        BorderThickness="1"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Закрыть" BorderBrush="{DynamicResource SgButtonOutlineBrush}">
                        <materialDesign:PackIcon Width="19" Height="19" Kind="Close" />
                    </Button>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Margin="14"
                Padding="10"
                Background="{DynamicResource SgSurfaceBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="1"
                CornerRadius="13">
                <ContentControl x:Name="logHost" />
            </Border>

            <Grid Grid.Row="2" Margin="18,0">
                <TextBlock
                    x:Name="txtWindowHint"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="{DynamicResource SgMutedBrush}"
                    Text="Окно можно растянуть или развернуть на весь экран. Новые записи появляются автоматически." />
            </Grid>
        </Grid>
    </Border>
</Window>
