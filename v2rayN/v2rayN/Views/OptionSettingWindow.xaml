<base:WindowBase xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:base="clr-namespace:v2rayN.Base" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework" xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib" x:Class="v2rayN.Views.OptionSettingWindow" Title="Настройки SG-Client" Width="1040" Height="760" MinWidth="860" MinHeight="620" x:TypeArguments="vms:OptionSettingViewModel" Background="{DynamicResource SgBackgroundBrush}" Icon="/Resources/v2rayN.ico" ResizeMode="CanResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner" WindowStyle="None" TextOptions.TextFormattingMode="Display" mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="7" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="SgWindowButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgButtonOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{DynamicResource SgButtonOutlineBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SgPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SgTabItem" TargetType="TabItem">
            <Setter Property="Width" Value="192"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,16,6"/>
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="14,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SgAccentSoftBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SgAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SgSettingCard" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="16,13"/>
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="13"/>
        </Style>


        <Style x:Key="SgComboItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgHoverBrush}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SgAccentSoftBrush}"/><Setter Property="Foreground" Value="{DynamicResource SgAccentBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SgValueComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SgComboItem}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite" Margin="12,0,4,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" IsHitTestVisible="False"/>
                                    <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Margin="10,4,2,4" Padding="2,0" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" Visibility="Hidden"/>
                                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"><materialDesign:PackIcon Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SgMutedBrush}" Kind="ChevronDown"/></Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Placement="Bottom" PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="300" Margin="0,5,0,0" Padding="5" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="10">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True"><Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/><Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}"/></Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBrush}"/><Setter TargetName="ComboBorder" Property="BorderThickness" Value="2"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SgValueTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource SgAccentSoftBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBrush}"/><Setter TargetName="InputBorder" Property="BorderThickness" Value="2"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="InputBorder" Property="Opacity" Value="0.55"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SgHelpIconButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Width" Value="28"/><Setter Property="Height" Value="28"/><Setter Property="MinWidth" Value="28"/><Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="5,-5,0,-5"/><Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}"/>
        </Style>

        <Style x:Key="SgPrimaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="MinWidth" Value="126"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="{DynamicResource SgOnButtonTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SgAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SgSecondaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18,0,8,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Настройки"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="btnHelp" Style="{StaticResource HeaderActionButton}" Content="Справка"/>
                        <Button x:Name="btnClose" Style="{StaticResource HeaderActionButton}" Content="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Margin="18,18,18,0" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource SgTabItem}" TabStripPlacement="Left">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Margin" Value="0,0,18,0"/>
                    </Style>
                </TabControl.Resources>

                <TabItem><TabItem.Header><StackPanel Orientation="Horizontal"><materialDesign:PackIcon Width="18" Height="18" Margin="0,0,10,0" Kind="TuneVariant"/><TextBlock VerticalAlignment="Center" Text="Настройки"/></StackPanel></TabItem.Header><ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="2,0,8,8"><!-- SG_SETTINGS_SINGLE_LIST_095: one Settings list without section headings; required transport diagnostics are always enabled. -->
                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Запускать вместе с Windows"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="SG-Client будет доступен сразу после входа в систему."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togAutoRun" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Сворачивать после запуска"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Главное окно не будет мешать после автоматического запуска."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togAutoHideStartup" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Восстанавливать TUN автоматически"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Перезапускать выбранный профиль после сна или восстановления сети."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togAutoRecoverTun" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Резервный профиль"/>
                                        <TextBlock x:Name="txtReserveProfileSetting" Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Не настроен"/>
                                    </StackPanel>
                                    <Button x:Name="btnReserveProfileSetting" Grid.Column="1" Width="130" Height="36" VerticalAlignment="Center" Style="{StaticResource SgMaterialOutlinedButton}" Content="Настроить"/>
                                </Grid>
                            </Border>

                            
                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Настраивать маршруты автоматически"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="SG-Client сам направляет трафик устройства через TUN."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togAutoRoute" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Строгая маршрутизация"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Снижает риск обхода туннеля отдельными приложениями."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togStrictRoute" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Поддержка IPv6"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Включайте только при наличии IPv6 у сервера и провайдера."/>
                                    </StackPanel>
                                    <ToggleButton x:Name="togEnableIPv6Address" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Сетевой стек"/>
                                            <Button Style="{StaticResource SgHelpIconButton}" Click="StackHelp_Click" ToolTip="Открыть справку"><materialDesign:PackIcon Width="16" Height="16" Kind="HelpCircleOutline"/></Button>
                                        </StackPanel>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Автоматически использует mixed для Hysteria2/sing-box. На Xray и AmneziaWG не влияет."/>
                                    </StackPanel>
                                    <ComboBox x:Name="cmbStack" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource SgValueComboBox}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Размер пакета MTU"/>
                                            <Button Style="{StaticResource SgHelpIconButton}" Click="MtuHelp_Click" ToolTip="Открыть справку"><materialDesign:PackIcon Width="16" Height="16" Kind="HelpCircleOutline"/></Button>
                                        </StackPanel>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Можно ввести своё значение 1280–9000. Рекомендуется: Xray 1500; Hysteria2/sing-box 9000; AmneziaWG — значение из профиля."/>
                                    </StackPanel>
                                    <ComboBox x:Name="cmbMtu" Grid.Column="1" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" LostKeyboardFocus="Mtu_LostKeyboardFocus" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource SgValueComboBox}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SgSettingCard}">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Адреса вне туннеля"/>
                                    <TextBlock Margin="0,4,0,10" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Необязательный список адресов через запятую."/>
                                    <TextBox x:Name="txtRouteExcludeAddress" MinHeight="52" ToolTip="Например: 192.168.1.0/24" Style="{StaticResource SgValueTextBox}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SgSettingCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Подробность журнала"/>
                                        <TextBlock Margin="0,4,16,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Для «Соединений» SG-Client использует безопасный уровень info; debug без необходимости не включается."/>
                                    </StackPanel>
                                    <ComboBox x:Name="cmbLogLevel" Grid.Column="1" Style="{StaticResource SgValueComboBox}"/>
                                </Grid>
                            </Border>
                        </StackPanel></ScrollViewer></TabItem><TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="18" Height="18" Margin="0,0,10,0" Kind="InformationOutline"/>
                            <TextBlock VerticalAlignment="Center" Text="О программе"/>
                        </StackPanel>
                    </TabItem.Header>
                    <!-- SG_ABOUT_FIT_095: compact About page fits without inner scrolling or fixed-width overflow. -->
                    <!-- SG_ABOUT_BUILD_095: About page displays build 095. -->
                    <Border Margin="2,0,8,8" Padding="20" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Width="64" Height="64" HorizontalAlignment="Center">
                                <Polygon Fill="{DynamicResource SgLogoFillBrush}" Points="32,2 60,17 60,47 32,62 4,47 4,17" Stroke="{DynamicResource SgAccentBrush}" StrokeThickness="2"/>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="SG"/>
                            </Grid>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                                <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="SG-Client"/>
                                <TextBlock Margin="0,3,0,0" HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="Сборка 095"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" MaxWidth="720" Margin="0,10,0,14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgMutedBrush}" Text="Единый Windows-клиент для профилей SG-Panel и SG-AWG-Panel. Поддерживает TUN, системный прокси Windows и локальный HTTP/SOCKS-прокси."/>

                            <Grid Grid.Row="3" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Padding="14" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="13">
                                    <StackPanel>
                                        <TextBlock FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="ПОДДЕРЖИВАЕМЫЕ ПРОФИЛИ"/>
                                        <TextBlock Margin="0,7,0,0" FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgTextBrush}" TextWrapping="Wrap" Text="VLESS REALITY и TLS&#10;XHTTP и raw/TCP&#10;Hysteria2&#10;AmneziaWG&#10;Trojan и AnyTLS"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Padding="14" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="13">
                                    <StackPanel>
                                        <TextBlock FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="ЯДРА И КОМПОНЕНТЫ"/>
                                        <TextBlock Margin="0,7,0,0" FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgTextBrush}" TextWrapping="Wrap" Text="Xray-core и sing-box&#10;AmneziaWG и Wintun&#10;Основа v2rayN&#10;.NET 10 · WPF&#10;Windows x64"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Padding="14" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="13">
                                    <StackPanel>
                                        <TextBlock FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="ВОЗМОЖНОСТИ"/>
                                        <TextBlock Margin="0,7,0,0" FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgTextBrush}" TextWrapping="Wrap" Text="Умная маршрутизация и GeoFiles&#10;DNS и Kill Switch&#10;Раздельный TUN&#10;Маскировка DPI&#10;Подписки и резервные копии"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4" Margin="0,14,0,0" HorizontalAlignment="Center">
                                <Separator Width="560" Margin="0,0,0,10" Background="{DynamicResource SgBorderBrush}"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="10.5" Foreground="{DynamicResource SgTextBrush}" Text="Интерфейс и сборка: Ser.Gor · 2026"/>
                                <TextBlock MaxWidth="680" Margin="0,5,0,0" TextAlignment="Center" TextWrapping="Wrap" FontSize="9.5" LineHeight="15" Foreground="{DynamicResource SgMutedBrush}" Text="Компоненты с открытым исходным кодом, лицензии и ссылки перечислены в THIRD-PARTY-NOTICES.md."/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Padding="18,12" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,15,15">
                <Grid>
                    <TextBlock x:Name="txtFooterStatus" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="Изменения будут применены после нажатия кнопки справа."/>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="btnCancel" Margin="0,0,10,0" Content="Отмена" Style="{StaticResource SgSecondaryButton}"/>
                        <Button x:Name="btnSave" Content="Применить" IsDefault="True" Style="{StaticResource SgPrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</base:WindowBase>
