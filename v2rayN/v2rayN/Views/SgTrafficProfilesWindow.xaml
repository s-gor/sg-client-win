<Window
    x:Class="v2rayN.Views.SgTrafficProfilesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="SG Client — Статистика трафика"
    Width="1120"
    Height="760"
    MinWidth="900"
    MinHeight="600"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="7"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TrafficWindowButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MonthSummaryCard" TargetType="Border">
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Background" Value="{DynamicResource SgHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="IsTabStop" Value="False" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SgAccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TrafficCenteredCellText" TargetType="TextBlock">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border
        Background="{DynamicResource SgBackgroundBrush}"
        BorderBrush="{DynamicResource SgBorderStrongBrush}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="22,0,12,0"
                Background="{DynamicResource SgHeaderBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="15,15,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Статистика трафика" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="10.5"
                            Foreground="{DynamicResource SgMutedBrush}"
                            Text="Общий объём за текущий месяц и распределение по профилям" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        Content="Обновить"
                        Click="Refresh_Click"
                        Style="{StaticResource TrafficWindowButton}" />
                    <Button
                        Grid.Column="2"
                        Width="96"
                        Content="Закрыть"
                        Click="Close_Click"
                        Style="{StaticResource TrafficWindowButton}" />
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Margin="20,18,20,12"
                Padding="16,13"
                Background="{DynamicResource SgAccentSoftBrush}"
                BorderBrush="{DynamicResource SgAccentBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            x:Name="txtMonthPeriod"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Текущий месяц" />
                        <TextBlock
                            x:Name="txtSummary"
                            Margin="0,5,0,0"
                            FontSize="10.5"
                            Foreground="{DynamicResource SgMutedBrush}"
                            Text="Трафик за текущий месяц пока не зафиксирован" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Text="Учитывается только трафик через VPN-профили" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20,0,20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MonthSummaryCard}">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="СКАЧАНО ЗА МЕСЯЦ" />
                        <TextBlock x:Name="txtMonthDownload" Margin="0,7,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource SgTrafficDownloadBrush}" Text="0 Б" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource MonthSummaryCard}">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="ОТПРАВЛЕНО ЗА МЕСЯЦ" />
                        <TextBlock x:Name="txtMonthUpload" Margin="0,7,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource SgTrafficUploadBrush}" Text="0 Б" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource MonthSummaryCard}">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="ОБЩИЙ ТРАФИК" />
                        <TextBlock x:Name="txtMonthTotal" Margin="0,7,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource SgAccentBrush}" Text="0 Б" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="20,0,20,0">
                <DataGrid
                    x:Name="dgProfiles"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Rows}"
                    RowHeaderWidth="0"
                    SelectionMode="Single"
                    SelectionUnit="FullRow"
                    Background="{DynamicResource SgSurfaceBrush}"
                    BorderBrush="{DynamicResource SgBorderBrush}"
                    BorderThickness="1"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="2.25*" Binding="{Binding ProfileName}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Профиль / маршрут" />
                        <DataGridTextColumn Width="1.1*" Binding="{Binding MonthDownloadDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Скачано" />
                        <DataGridTextColumn Width="1.1*" Binding="{Binding MonthUploadDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Отправлено" />
                        <DataGridTextColumn Width="1.1*" Binding="{Binding MonthTotalDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Всего за месяц" />
                        <DataGridTextColumn Width="0.75*" Binding="{Binding MonthShareDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Доля" />
                        <DataGridTextColumn Width="1.25*" Binding="{Binding TodayDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Сегодня" />
                        <DataGridTextColumn Width="1.25*" Binding="{Binding LastUsedDisplay}" ElementStyle="{StaticResource TrafficCenteredCellText}" Header="Последнее использование" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="emptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon
                        Width="42"
                        Height="42"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Kind="ChartBoxOutline" />
                    <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Text="Статистика за месяц пока пуста" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="10.5"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Text="Подключитесь и передайте данные через VPN или Direct." />
                </StackPanel>
            </Grid>

            <Border Grid.Row="4" Margin="20,0" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="9.5"
                    Foreground="{DynamicResource SgMutedBrush}"
                    Text="Статистика сохраняется между запусками в guiConfigs\sg-traffic.json; VPN распределяется по профилям, Direct показан отдельно." />
            </Border>
        </Grid>
    </Border>
</Window>
