<Window
    x:Class="v2rayN.Views.SgAwgTextImportWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Импорт конфигурации AmneziaWG"
    Width="920"
    Height="720"
    MinWidth="780"
    MinHeight="580"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="7"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="HeaderActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Border Margin="0" Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="20,0,10,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Импорт конфигурации AmneziaWG" />
                        <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Вставьте полный текст из SG-AWG-Panel: разделы [Interface] и [Peer]" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource HeaderActionButton}" Click="Cancel_Click" Content="Закрыть" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,18,20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Полный текст конфигурации" />
                        <TextBlock Margin="0,3,12,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Приватный ключ сохраняется только в локальном профиле и не выводится в журнал." />
                    </StackPanel>
                    <Button Grid.Column="1" Padding="14,7" Click="Paste_Click" Style="{StaticResource SgMaterialOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,7,0" Kind="ContentPaste" />
                            <TextBlock Text="Вставить из буфера" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBox
                    x:Name="txtConfig"
                    Grid.Row="1"
                    Margin="0,12,0,14"
                    MinHeight="250"
                    Padding="12,10"
                    AcceptsReturn="True"
                    AcceptsTab="True"
                    Background="{DynamicResource SgSurfaceSoftBrush}"
                    BorderBrush="{DynamicResource SgBorderBrush}"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="{DynamicResource SgTextBrush}"
                    HorizontalScrollBarVisibility="Auto"
                    SpellCheck.IsEnabled="False"
                    TextChanged="Config_TextChanged"
                    TextWrapping="NoWrap"
                    VerticalScrollBarVisibility="Auto" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="14" Background="{DynamicResource SgSidebarBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="txtValidationTitle" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Конфигурация ещё не проверена" />
                            <TextBlock x:Name="txtPreviewType" Grid.Row="1" Margin="0,7,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" />
                            <TextBlock x:Name="txtPreviewEndpoint" Grid.Row="2" Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="txtPreviewAddress" Grid.Row="3" Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="txtPreviewRoute" Grid.Row="4" Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Padding="14" Background="{DynamicResource SgSidebarBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Имя профиля" />
                            <TextBlock Margin="0,3,0,8" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Можно изменить перед добавлением." />
                            <TextBox x:Name="txtProfileName" Height="40" Padding="10,0" VerticalContentAlignment="Center" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" Foreground="{DynamicResource SgTextBrush}" Text="AmneziaWG" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Margin="0,14,0,0" Padding="12" Background="{DynamicResource SgAccentSoftBrush}" BorderBrush="{DynamicResource SgAccentBorderBrush}" BorderThickness="1" CornerRadius="11">
                    <TextBlock FontSize="10.5" Foreground="{DynamicResource SgTextBrush}" TextWrapping="Wrap" Text="SG Client проверит структуру, адрес клиента, Endpoint, порт, ключи, AllowedIPs и параметры AmneziaWG. Кнопка «Добавить» станет доступна только после успешной проверки." />
                </Border>
            </Grid>

            <Border Grid.Row="2" Padding="20,14" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,15,15">
                <Grid>
                    <Button HorizontalAlignment="Left" Width="124" Height="38" Click="Validate_Click" Style="{StaticResource SgMaterialOutlinedButton}" Content="Проверить" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Width="112" Height="38" Click="Cancel_Click" Style="{StaticResource SgMaterialOutlinedButton}" Content="Отмена" />
                        <Button x:Name="btnAdd" Width="150" Height="38" Margin="10,0,0,0" Click="Add_Click" IsEnabled="False" Style="{StaticResource SgMaterialRaisedButton}" Content="Добавить" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
