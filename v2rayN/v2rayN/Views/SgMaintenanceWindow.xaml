<Window
    x:Class="v2rayN.Views.SgMaintenanceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:views="clr-namespace:v2rayN.Views"
    Title="Обслуживание SG Client"
    Width="974"
    Height="714"
    MinWidth="840"
    MinHeight="650"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="7" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="MaintenanceCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="HeaderActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PrimaryActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Background" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgOnButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SecondaryActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerActionButton" BasedOn="{StaticResource SecondaryActionButton}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource SgErrorBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgErrorBrush}" />
            <Setter Property="MinWidth" Value="82" />
        </Style>

        <Style x:Key="WarningActionButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{DynamicResource SgWarningSoftBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgWarningBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgWarningBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="WarningBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="WarningBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="WarningBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TabButton" TargetType="ToggleButton">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SgAccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="BackupListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="XraySourceChoice" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="ChoiceBorder"
                            MinWidth="132"
                            Height="38"
                            Padding="13,0"
                            Background="{DynamicResource SgSurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource SgBorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                <Ellipse
                                    x:Name="ChoiceDot"
                                    Width="7"
                                    Height="7"
                                    Margin="0,0,7,0"
                                    Fill="{DynamicResource SgMutedBrush}" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="Background" Value="{DynamicResource SgAccentSoftBrush}" />
                                <Setter TargetName="ChoiceBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
                                <Setter TargetName="ChoiceDot" Property="Fill" Value="{DynamicResource SgAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaintenanceTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SgAccentSoftBrush}" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62" />
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="20,0,10,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Обслуживание" />
                        <TextBlock Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Резервные копии и обновления" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource HeaderActionButton}" Click="Help_Click" Content="Справка" ToolTip="Открыть справку для текущей вкладки" />
                        <Button Margin="8,0,0,0" Style="{StaticResource HeaderActionButton}" Click="Close_Click" Content="Закрыть" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="20,0" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="tabBackups" IsChecked="True" Click="BackupsTab_Click" Style="{StaticResource TabButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="17" Height="17" Margin="0,0,8,0" Kind="ContentCopy" />
                            <TextBlock Text="Резервные копии" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="tabUpdates" Click="UpdatesTab_Click" Style="{StaticResource TabButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="17" Height="17" Margin="0,0,8,0" Kind="Reload" />
                            <TextBlock Text="Обновления" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="18">
                <ScrollViewer x:Name="backupsPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,12" Style="{StaticResource MaintenanceCard}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="● НОВАЯ КОПИЯ" />
                                    <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Создать резервную копию" />
                                    <TextBlock Margin="0,6,20,0" MaxWidth="650" FontSize="11.5" LineHeight="18" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Сохраняются профили Xray/sing-box, локальные профили AmneziaWG, настройки, подписки, правила маршрутизации и статистика трафика. Журналы, временный AWG-runtime и движки в копию не входят." />
                                    <TextBlock x:Name="txtBackupStatus" Margin="0,10,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Локальные копии хранятся внутри папки клиента. Перед удалением используйте «Экспортировать копию в ZIP»." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="btnCreateBackup" Style="{StaticResource PrimaryActionButton}" Click="CreateBackup_Click" Content="Создать точку восстановления" />
                                    <Button Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}" Click="CreateBackupFile_Click" Content="Экспортировать копию в ZIP" />
                                    <Button Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}" Click="VerifyBackupFile_Click" Content="Проверить ZIP" />
                                    <Button Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}" Click="RestoreBackupFromFile_Click" Content="Восстановить из ZIP" />
                                    <Button Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}" Click="OpenBackupFolder_Click" Content="Открыть папку копий" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,12" Style="{StaticResource MaintenanceCard}">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="● БЕЗОПАСНОЕ ВОССТАНОВЛЕНИЕ" />
                                <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Проверка перед применением" />
                                <TextBlock Margin="0,6,0,12" FontSize="11.5" LineHeight="18" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Перед восстановлением SG Client проверяет архив и создаёт страховочную копию текущего состояния. После применения клиент перезапускается." />
                                <UniformGrid Columns="4">
                                    <Border Margin="0,0,8,0" Padding="12" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <StackPanel><TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="1" /><TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Проверка копии" /><TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Структура ZIP и папка guiConfigs" /></StackPanel>
                                    </Border>
                                    <Border Margin="0,0,8,0" Padding="12" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <StackPanel><TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="2" /><TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Страховочная копия" /><TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Текущее состояние сохраняется заранее" /></StackPanel>
                                    </Border>
                                    <Border Margin="0,0,8,0" Padding="12" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <StackPanel><TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="3" /><TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Применение" /><TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Профили и настройки заменяются" /></StackPanel>
                                    </Border>
                                    <Border Padding="12" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <StackPanel><TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="4" /><TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Перезапуск" /><TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="SG Client запускается с восстановленными данными" /></StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MaintenanceCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="● ТОЧКИ ВОССТАНОВЛЕНИЯ" />
                                        <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Сохранённые копии" />
                                        <TextBlock x:Name="txtLastBackup" Margin="0,5,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Копий пока нет" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Padding="10,4" VerticalAlignment="Top" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="10">
                                        <TextBlock x:Name="txtBackupCount" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="0 копий" />
                                    </Border>
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <TextBlock x:Name="txtNoBackups" Margin="0,24" HorizontalAlignment="Center" FontSize="12" Foreground="{DynamicResource SgMutedBrush}" Text="Локальных копий пока нет. Для новой установки можно выбрать «Восстановить из ZIP»." />
                                    <ListBox x:Name="lstBackups" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource BackupListItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="13" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="110" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="{Binding DisplayDate}" />
                                                            <TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="{Binding VersionText}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="{Binding SizeText}" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                            <Button Margin="0,0,7,0" Tag="{Binding FilePath}" Style="{StaticResource SecondaryActionButton}" Click="RestoreBackup_Click" Content="Восстановить" />
                                                            <Button Margin="0,0,7,0" MinWidth="86" Tag="{Binding FilePath}" Style="{StaticResource SecondaryActionButton}" Click="OpenBackup_Click" Content="Показать" />
                                                            <Button Tag="{Binding FilePath}" Style="{StaticResource DangerActionButton}" Click="DeleteBackup_Click" Content="Удалить" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="updatesPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,12" Style="{StaticResource MaintenanceCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgAccentBrush}" Text="● ПРОВЕРКА КОМПОНЕНТОВ" />
                                    <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="SG Client, sing-box и локальные компоненты" />
                                    <TextBlock Margin="0,6,18,0" MaxWidth="650" FontSize="11.5" LineHeight="18" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Этот блок проверяет версии и состояние файлов. Безопасное ручное обновление Xray и sing-box выполняется в отдельных карточках ниже и не зависит от настроек SG Client." />
                                    <TextBlock x:Name="txtUpdateCheckedAt" Margin="0,9,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="Проверка ещё не выполнялась" />
                                </StackPanel>
                                <Button x:Name="btnCheckUpdates" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource PrimaryActionButton}" Click="CheckUpdates_Click" Content="Проверить остальные" />
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,12" Style="{StaticResource MaintenanceCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Ручное обновление Xray" />
                                        <TextBlock x:Name="txtXrayInstalled" Margin="0,6,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Установлена: определение версии…" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="1"
                                        Width="152"
                                        Height="46"
                                        Background="{DynamicResource SgWarningSoftBrush}"
                                        BorderBrush="{DynamicResource SgWarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11.5"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource SgWarningBrush}"
                                            Text="Экспертный режим" />
                                    </Border>
                                </Grid>

                                <Border Margin="0,14,0,0" Padding="12" Background="{DynamicResource SgWarningSoftBrush}" BorderBrush="{DynamicResource SgWarningBrush}" BorderThickness="1" CornerRadius="10">
                                    <TextBlock FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgWarningBrush}" TextWrapping="Wrap" Text="Несовместимая версия может нарушить подключение. Кнопка обновления станет доступна только после проверки версии, SHA-256 и текущего config.json выбранным Xray." />
                                </Border>

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="1. ИСТОЧНИК И ВЕРСИЯ" />
                                <WrapPanel>
                                    <RadioButton x:Name="rbXrayStable" Tag="stable" IsChecked="True" Click="XraySource_Click" Style="{StaticResource XraySourceChoice}" Content="Стабильный" />
                                    <RadioButton x:Name="rbXrayPreview" Tag="preview" Click="XraySource_Click" Style="{StaticResource XraySourceChoice}" Content="Предварительный" />
                                    <RadioButton x:Name="rbXrayExact" Tag="exact" Click="XraySource_Click" Style="{StaticResource XraySourceChoice}" Content="Точная версия" />
                                    <RadioButton x:Name="rbXrayLocal" Tag="local" Click="XraySource_Click" Style="{StaticResource XraySourceChoice}" Content="Локальный файл" />
                                </WrapPanel>

                                <Grid x:Name="pnlXrayExact" Margin="0,4,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,5" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="НОМЕР ВЕРСИИ" />
                                        <TextBox x:Name="txtXrayExactVersion" Style="{StaticResource MaintenanceTextBox}" TextChanged="XrayExactVersion_Changed" ToolTip="Например: 26.6.27 или v26.6.27" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,8" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Укажите официальный тег Xray. SG Client найдёт этот выпуск и проверит официальный архив." />
                                </Grid>

                                <Grid x:Name="pnlXrayLocal" Margin="0,4,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtXrayLocalPath" IsReadOnly="True" Style="{StaticResource MaintenanceTextBox}" Text="Файл не выбран" />
                                    <Button x:Name="btnXrayChooseLocal" Grid.Column="2" Click="XrayChooseLocal_Click" Style="{StaticResource SecondaryActionButton}" Content="Выбрать xray.exe" />
                                </Grid>

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="2. ПОДКЛЮЧЕНИЕ К СЕРВЕРУ РЕЛИЗОВ" />
                                <WrapPanel>
                                    <RadioButton x:Name="rbXrayCurrentRoute" Tag="current" IsChecked="True" Click="XrayNetwork_Click" Style="{StaticResource XraySourceChoice}" Content="Текущий маршрут / VPN" />
                                    <RadioButton x:Name="rbXrayDirect" Tag="direct" Click="XrayNetwork_Click" Style="{StaticResource XraySourceChoice}" Content="Без системного прокси" />
                                </WrapPanel>
                                <TextBlock Margin="0,-1,0,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="«Без системного прокси» отключает Windows Proxy только для загрузки релиза. При активном TUN сетевой маршрут всё равно проходит через TUN." />

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="3. ПРОВЕРКА КАНДИДАТА" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="Выбранная версия" />
                                    <TextBlock x:Name="txtXrayCandidateVersion" Grid.Column="1" Margin="0,0,18,7" FontWeight="SemiBold" Text="—" />
                                    <TextBlock Grid.Column="2" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="Источник" />
                                    <TextBlock x:Name="txtXrayCandidateSource" Grid.Column="3" Margin="0,0,0,7" Text="—" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="SHA-256 xray.exe" />
                                    <TextBlock x:Name="txtXrayCandidateSha" Grid.Row="1" Grid.Column="1" Margin="0,0,18,7" FontFamily="Consolas" FontSize="10" Text="—" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="config.json" />
                                    <TextBlock x:Name="txtXrayCandidateConfig" Grid.Row="1" Grid.Column="3" Margin="0,0,0,7" Text="Не проверен" />
                                </Grid>

                                <TextBlock x:Name="txtXrayManualStatus" Margin="0,8,0,0" FontSize="10.8" Foreground="{DynamicResource SgMutedBrush}" Text="Выберите источник и нажмите «Проверить выбранную версию»." TextWrapping="Wrap" />

                                <WrapPanel Margin="0,15,0,0">
                                    <Button x:Name="btnXrayPrepare" Margin="0,0,9,8" Click="XrayPrepare_Click" Style="{StaticResource SecondaryActionButton}" Content="Проверить выбранную версию" />
                                    <Button x:Name="btnXrayInstall" Margin="0,0,9,8" IsEnabled="False" Click="XrayInstall_Click" Style="{StaticResource PrimaryActionButton}" Content="Обновить Xray" />
                                    <Button Margin="0,0,0,8" Click="OpenXrayBackupFolder_Click" Style="{StaticResource SecondaryActionButton}" Content="Резервные копии Xray" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12" Style="{StaticResource MaintenanceCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Ручное обновление sing-box" />
                                        <TextBlock x:Name="txtSingManualInstalled" Margin="0,6,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Установлена: определение версии…" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="1"
                                        Width="152"
                                        Height="46"
                                        Background="{DynamicResource SgWarningSoftBrush}"
                                        BorderBrush="{DynamicResource SgWarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11.5"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource SgWarningBrush}"
                                            Text="Экспертный режим" />
                                    </Border>
                                </Grid>

                                <Border Margin="0,14,0,0" Padding="12" Background="{DynamicResource SgWarningSoftBrush}" BorderBrush="{DynamicResource SgWarningBrush}" BorderThickness="1" CornerRadius="10">
                                    <TextBlock FontSize="10.5" LineHeight="17" Foreground="{DynamicResource SgWarningBrush}" TextWrapping="Wrap" Text="SG Client проверяет официальный SHA-256, запуск выбранного sing-box и текущую конфигурацию до замены. Перед установкой сохраняется вся папка sing_box; при любой ошибке выполняется автоматический откат." />
                                </Border>

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="1. ИСТОЧНИК И ВЕРСИЯ" />
                                <WrapPanel>
                                    <RadioButton x:Name="rbSingStable" Tag="stable" IsChecked="True" Click="SingSource_Click" Style="{StaticResource XraySourceChoice}" Content="Стабильный" />
                                    <RadioButton x:Name="rbSingPreview" Tag="preview" Click="SingSource_Click" Style="{StaticResource XraySourceChoice}" Content="Предварительный" />
                                    <RadioButton x:Name="rbSingExact" Tag="exact" Click="SingSource_Click" Style="{StaticResource XraySourceChoice}" Content="Точная версия" />
                                    <RadioButton x:Name="rbSingLocal" Tag="local" Click="SingSource_Click" Style="{StaticResource XraySourceChoice}" Content="Локальный файл" />
                                </WrapPanel>

                                <Grid x:Name="pnlSingExact" Margin="0,4,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,5" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="НОМЕР ВЕРСИИ" />
                                        <TextBox x:Name="txtSingExactVersion" Style="{StaticResource MaintenanceTextBox}" TextChanged="SingExactVersion_Changed" ToolTip="Например: 1.13.1 или v1.13.1" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,8" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Укажите официальный тег sing-box. SG Client найдёт выпуск, проверит официальный архив и исполняемый файл." />
                                </Grid>

                                <Grid x:Name="pnlSingLocal" Margin="0,4,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtSingLocalPath" IsReadOnly="True" Style="{StaticResource MaintenanceTextBox}" Text="Файл не выбран" />
                                    <Button x:Name="btnSingChooseLocal" Grid.Column="2" Click="SingChooseLocal_Click" Style="{StaticResource SecondaryActionButton}" Content="Выбрать sing-box.exe" />
                                </Grid>

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="2. ПОДКЛЮЧЕНИЕ К СЕРВЕРУ РЕЛИЗОВ" />
                                <WrapPanel>
                                    <RadioButton x:Name="rbSingCurrentRoute" Tag="current" IsChecked="True" Click="SingNetwork_Click" Style="{StaticResource XraySourceChoice}" Content="Текущий маршрут / VPN" />
                                    <RadioButton x:Name="rbSingDirect" Tag="direct" Click="SingNetwork_Click" Style="{StaticResource XraySourceChoice}" Content="Без системного прокси" />
                                </WrapPanel>
                                <TextBlock Margin="0,-1,0,0" FontSize="10" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="«Без системного прокси» отключает Windows Proxy только на время загрузки релиза. При активном TUN маршрут остаётся через TUN." />

                                <TextBlock Margin="0,17,0,7" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SgMutedBrush}" Text="3. ПРОВЕРКА КАНДИДАТА" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="Выбранная версия" />
                                    <TextBlock x:Name="txtSingCandidateVersion" Grid.Column="1" Margin="0,0,18,7" FontWeight="SemiBold" Text="—" />
                                    <TextBlock Grid.Column="2" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="Источник" />
                                    <TextBlock x:Name="txtSingCandidateSource" Grid.Column="3" Margin="0,0,0,7" Text="—" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="SHA-256 sing-box.exe" />
                                    <TextBlock x:Name="txtSingCandidateSha" Grid.Row="1" Grid.Column="1" Margin="0,0,18,7" FontFamily="Consolas" FontSize="10" Text="—" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,10,7" Foreground="{DynamicResource SgMutedBrush}" Text="config.json" />
                                    <TextBlock x:Name="txtSingCandidateConfig" Grid.Row="1" Grid.Column="3" Margin="0,0,0,7" Text="Не проверен" />
                                </Grid>

                                <TextBlock x:Name="txtSingManualStatus" Margin="0,8,0,0" FontSize="10.8" Foreground="{DynamicResource SgMutedBrush}" Text="Выберите источник и нажмите «Проверить выбранную версию»." TextWrapping="Wrap" />

                                <WrapPanel Margin="0,15,0,0">
                                    <Button x:Name="btnSingPrepare" Margin="0,0,9,8" Click="SingPrepare_Click" Style="{StaticResource SecondaryActionButton}" Content="Проверить выбранную версию" />
                                    <Button x:Name="btnSingInstall" Margin="0,0,9,8" IsEnabled="False" Click="SingInstall_Click" Style="{StaticResource PrimaryActionButton}" Content="Обновить sing-box" />
                                    <Button Margin="0,0,0,8" Click="OpenSingBackupFolder_Click" Style="{StaticResource SecondaryActionButton}" Content="Резервные копии sing-box" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MaintenanceCard}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="SG Client" />
                                        <Border Grid.Column="1" Padding="8,3" Background="{DynamicResource SgAccentSoftBrush}" BorderBrush="{DynamicResource SgAccentBorderBrush}" BorderThickness="1" CornerRadius="8"><TextBlock FontSize="10" Foreground="{DynamicResource SgAccentBrush}" Text="ПРИЛОЖЕНИЕ" /></Border>
                                    </Grid>
                                    <TextBlock x:Name="txtSgInstalled" Margin="0,12,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Установлена: 0.0.57" />
                                    <CheckBox x:Name="chkSgPreRelease" Margin="0,10,0,0" Foreground="{DynamicResource SgWarningBrush}" Content="Учитывать предварительные версии SG Client" />
                                    <TextBlock x:Name="txtSgStatus" Margin="0,8,0,0" FontSize="11.5" Foreground="{DynamicResource SgTextBrush}" Text="Нажмите «Проверить остальные»" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource MaintenanceCard}">
                                <StackPanel>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock FontSize="17" FontWeight="SemiBold" Text="sing-box" /><Border Grid.Column="1" Padding="8,3" Background="{DynamicResource SgAccentSoftBrush}" BorderBrush="{DynamicResource SgAccentBorderBrush}" BorderThickness="1" CornerRadius="8"><TextBlock FontSize="10" Foreground="{DynamicResource SgAccentBrush}" Text="РУЧНОЕ ОБНОВЛЕНИЕ" /></Border></Grid>
                                    <TextBlock x:Name="txtSingInstalled" Margin="0,12,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Определение версии…" />
                                    <TextBlock x:Name="txtSingStatus" Margin="0,8,0,0" FontSize="11.5" Foreground="{DynamicResource SgTextBrush}" Text="Нажмите «Проверить остальные»" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource MaintenanceCard}">
                                <StackPanel>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock FontSize="17" FontWeight="SemiBold" Text="AmneziaWG" /><Border Grid.Column="1" Padding="8,3" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="8"><TextBlock FontSize="10" Foreground="{DynamicResource SgMutedBrush}" Text="ПАКЕТ SG" /></Border></Grid>
                                    <TextBlock x:Name="txtAwgInstalled" Margin="0,12,0,0" FontSize="11" Foreground="{DynamicResource SgMutedBrush}" Text="Определение версии…" />
                                    <TextBlock x:Name="txtAwgStatus" Margin="0,8,0,0" FontSize="11.5" Foreground="{DynamicResource SgTextBrush}" Text="Обновляется только вместе с проверенным пакетом SG Client" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4" Grid.ColumnSpan="3" Padding="14" Background="{DynamicResource SgSurfaceSoftBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <TextBlock FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" Text="Xray и sing-box обновляются только вручную после отдельной проверки. Для каждого ядра создаётся резервная копия и выполняется автоматический откат при ошибке. AmneziaWG заменяется только вместе с проверенным пакетом SG Client." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <Grid x:Name="confirmOverlay" Grid.RowSpan="3" Visibility="Collapsed" Background="#99000000">
                <Border Width="500" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource SgSurfaceRaisedBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="15">
                    <StackPanel>
                        <TextBlock x:Name="txtConfirmTitle" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource SgTextBrush}" Text="Подтверждение" />
                        <TextBlock x:Name="txtConfirmBody" Margin="0,10,0,0" FontSize="11.5" LineHeight="18" Foreground="{DynamicResource SgMutedBrush}" TextWrapping="Wrap" />
                        <StackPanel Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Style="{StaticResource SecondaryActionButton}" Click="CancelConfirm_Click" Content="Отмена" />
                            <Button x:Name="btnConfirmAction" Style="{StaticResource PrimaryActionButton}" Click="ConfirmAction_Click" Content="Продолжить" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
