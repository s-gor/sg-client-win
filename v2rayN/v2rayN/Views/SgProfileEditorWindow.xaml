<Window
    x:Class="v2rayN.Views.SgProfileEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Редактор профиля SG Client"
    Width="974"
    Height="714"
    MinWidth="900"
    MinHeight="680"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="7"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="EditorCard" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SgMutedBrush}" />
        </Style>

        <Style x:Key="EditorTextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}" TargetType="TextBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SgAccentSoftBrush}" />
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="False" />
        </Style>

        <Style x:Key="EditorCodeTextBox" BasedOn="{StaticResource EditorTextBox}" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="EditorComboItem" TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="11,6" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SgSelectedBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SgAccentBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SgAccentSoftBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource SgOffBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="11,3" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboItem}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border
                                x:Name="EditorComboBorder"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        x:Name="EditorComboContent"
                                        Margin="2,0,6,0"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        IsHitTestVisible="False" />
                                    <TextBox
                                        x:Name="PART_EditableTextBox"
                                        Grid.Column="0"
                                        Margin="0"
                                        Padding="2,0,6,0"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="{DynamicResource SgAccentBrush}"
                                        Foreground="{TemplateBinding Foreground}"
                                        IsReadOnly="{TemplateBinding IsReadOnly}"
                                        SelectionBrush="{DynamicResource SgAccentSoftBrush}"
                                        Visibility="Collapsed" />
                                    <Path
                                        Grid.Column="1"
                                        Width="10"
                                        Height="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource SgMutedBrush}"
                                        Data="M 0 0 L 5 5 L 10 0 Z" />
                                </Grid>
                            </Border>
                            <ToggleButton
                                x:Name="DropDownToggle"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                HorizontalAlignment="Stretch"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="320"
                                    Margin="0,5,0,0"
                                    Padding="3"
                                    Background="{DynamicResource SgSurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource SgBorderStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <ScrollViewer
                                        CanContentScroll="True"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="EditorComboContent" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="DropDownToggle" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="DropDownToggle" Property="Width" Value="30" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="EditorComboBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorComboBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,18,4" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
        </Style>

        <Style x:Key="PrimaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="MinWidth" Value="135" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="16,5" />
            <Setter Property="Background" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgOnButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13.5" />
        </Style>

        <Style x:Key="SecondaryButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="15,5" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HeaderButton" BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="34" />
        </Style>
    </Window.Resources>

    <Border
        Background="{DynamicResource SgBackgroundBrush}"
        BorderBrush="{DynamicResource SgBorderStrongBrush}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="82" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="20,0,10,0"
                Background="{DynamicResource SgHeaderBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="15,15,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            x:Name="txtWindowTitle"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SgTextBrush}"
                            Text="Редактор профиля" />
                        <TextBlock
                            x:Name="txtWindowSubtitle"
                            Margin="0,3,0,0"
                            FontSize="10.5"
                            Foreground="{DynamicResource SgMutedBrush}"
                            Text="Все параметры, которые SG Client передаёт выбранному ядру" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Click="Help_Click" Content="Справка" Style="{StaticResource HeaderButton}" />
                        <Button Margin="8,0,0,0" Click="Close_Click" Content="Закрыть" Style="{StaticResource HeaderButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer
                Grid.Row="1"
                Margin="18,16,18,8"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="editorHost" />
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="18,12"
                Background="{DynamicResource SgHeaderBrush}"
                BorderBrush="{DynamicResource SgBorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,15,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="txtStatus"
                        MaxWidth="560"
                        VerticalAlignment="Center"
                        FontSize="10.5"
                        Foreground="{DynamicResource SgMutedBrush}"
                        Text="Профиль загружается…"
                        TextWrapping="Wrap" />
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button
                            Margin="0,0,9,0"
                            Click="Validate_Click"
                            Content="Проверить"
                            Style="{StaticResource SecondaryButton}" />
                        <Button
                            x:Name="btnSave"
                            Margin="0,0,9,0"
                            Click="Save_Click"
                            Content="Сохранить"
                            Style="{StaticResource PrimaryButton}" />
                        <Button
                            x:Name="btnCopy"
                            Margin="0,0,9,0"
                            Click="Copy_Click"
                            Content="Создать копию"
                            Style="{StaticResource SecondaryButton}" />
                        <Button
                            Click="Reload_Click"
                            Content="Отменить" ToolTip="Отбросить несохранённые изменения"
                            Style="{StaticResource SecondaryButton}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
