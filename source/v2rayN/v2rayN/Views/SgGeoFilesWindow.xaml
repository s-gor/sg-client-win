<Window
    x:Class="v2rayN.Views.SgGeoFilesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:views="clr-namespace:v2rayN.Views"
    Title="GeoFiles SG Client"
    Width="974"
    Height="714"
    MinWidth="900"
    MinHeight="690"
    Background="{DynamicResource SgBackgroundBrush}"
    Foreground="{DynamicResource SgTextBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="7" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="GeoHeaderButton" BasedOn="{StaticResource SgWindowButtonBase}" TargetType="Button">
            <Setter Property="Width" Value="92" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SgBackgroundBrush}" BorderBrush="{DynamicResource SgBorderStrongBrush}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="20,0,10,0" Background="{DynamicResource SgHeaderBrush}" BorderBrush="{DynamicResource SgBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="19" FontWeight="SemiBold" Text="Источники GeoFiles" />
                        <TextBlock Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource SgMutedBrush}" Text="geoip.dat и geosite.dat · источник, SHA-256, проверка и безопасная замена" />
                    </StackPanel>
                    <Button Grid.Column="1" Click="Close_Click" Content="Закрыть" Style="{StaticResource GeoHeaderButton}" />
                </Grid>
            </Border>

            <views:SgGeoFilesPanel Grid.Row="1" Margin="18" />
        </Grid>
    </Border>
</Window>
