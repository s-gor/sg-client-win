<Application
    x:Class="v2rayN.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:v2rayN.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    ShutdownMode="OnExplicitShutdown"
    StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary xmlns:system="clr-namespace:System;assembly=mscorlib">
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Dark"
                    PrimaryColor="Green"
                    SecondaryColor="LightGreen" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- SG Client theme palette. Values are replaced at runtime by SgThemeManager. -->
            <SolidColorBrush x:Key="SgBackgroundBrush" Color="#0B121C" />
            <SolidColorBrush x:Key="SgHeaderBrush" Color="#0E1723" />
            <SolidColorBrush x:Key="SgSidebarBrush" Color="#101B29" />
            <SolidColorBrush x:Key="SgSurfaceBrush" Color="#111D2B" />
            <SolidColorBrush x:Key="SgSurfaceSoftBrush" Color="#0F1A27" />
            <SolidColorBrush x:Key="SgSurfaceRaisedBrush" Color="#162438" />
            <SolidColorBrush x:Key="SgBorderBrush" Color="#24364B" />
            <SolidColorBrush x:Key="SgBorderStrongBrush" Color="#34506B" />
            <SolidColorBrush x:Key="SgTextBrush" Color="#F4F7FA" />
            <SolidColorBrush x:Key="SgMutedBrush" Color="#8A9AAF" />
            <SolidColorBrush x:Key="SgAccentBrush" Color="#35D69A" />
            <SolidColorBrush x:Key="SgTrafficDownloadBrush" Color="#4DB8FF" />
            <SolidColorBrush x:Key="SgTrafficUploadBrush" Color="#39D6A0" />
            <SolidColorBrush x:Key="SgTunHeroBrush" Color="#10251F" />
            <SolidColorBrush x:Key="SgTunCardBrush" Color="#112A25" />
            <SolidColorBrush x:Key="SgTunCardBorderBrush" Color="#245C4A" />
            <SolidColorBrush x:Key="SgSystemProxyBrush" Color="#E9C46A" />
            <SolidColorBrush x:Key="SgSystemProxySoftBrush" Color="#3A321A" />
            <SolidColorBrush x:Key="SgSystemProxyBorderBrush" Color="#E9C46A" />
            <SolidColorBrush x:Key="SgSystemProxyHeroBrush" Color="#2B2618" />
            <SolidColorBrush x:Key="SgSystemProxyCardBrush" Color="#342D1B" />
            <SolidColorBrush x:Key="SgSystemProxyCardBorderBrush" Color="#6F5B24" />
            <SolidColorBrush x:Key="SgLocalProxyBrush" Color="#A78BFA" />
            <SolidColorBrush x:Key="SgLocalProxySoftBrush" Color="#2B2345" />
            <SolidColorBrush x:Key="SgLocalProxyBorderBrush" Color="#7059B0" />
            <SolidColorBrush x:Key="SgLocalProxyHeroBrush" Color="#1B1930" />
            <SolidColorBrush x:Key="SgLocalProxyCardBrush" Color="#211D39" />
            <SolidColorBrush x:Key="SgLocalProxyCardBorderBrush" Color="#4B3F77" />
            <SolidColorBrush x:Key="SgAccentSoftBrush" Color="#14372D" />
            <SolidColorBrush x:Key="SgAccentBorderBrush" Color="#2A7A5C" />
            <SolidColorBrush x:Key="SgSuccessBrush" Color="#35D69A" />
            <SolidColorBrush x:Key="SgSuccessSoftBrush" Color="#14372D" />
            <SolidColorBrush x:Key="SgWarningBrush" Color="#E9C46A" />
            <SolidColorBrush x:Key="SgWarningSoftBrush" Color="#3A321A" />
            <SolidColorBrush x:Key="SgErrorBrush" Color="#F08BA4" />
            <SolidColorBrush x:Key="SgErrorSoftBrush" Color="#3B1E2A" />
            <SolidColorBrush x:Key="SgOffBrush" Color="#65758A" />
            <SolidColorBrush x:Key="SgHoverBrush" Color="#17263A" />
            <SolidColorBrush x:Key="SgPressedBrush" Color="#20324A" />
            <SolidColorBrush x:Key="SgSelectedBrush" Color="#182A3E" />
            <SolidColorBrush x:Key="SgInputBrush" Color="#0E1926" />
            <SolidColorBrush x:Key="SgHeroBrush" Color="#111D2B" />
            <SolidColorBrush x:Key="SgHeroBusyBrush" Color="#211F18" />
            <SolidColorBrush x:Key="SgHeroErrorBrush" Color="#251820" />
            <SolidColorBrush x:Key="SgOnButtonBrush" Color="#EDF8F4" />
            <SolidColorBrush x:Key="SgOnButtonTextBrush" Color="#12392C" />
            <SolidColorBrush x:Key="SgLogoFillBrush" Color="#10242B" />
            <!-- Main action palette. SgThemeManager replaces these brushes for each SG Client theme. -->
            <SolidColorBrush x:Key="SgNeutralActionBrush" Color="#102238" />
            <SolidColorBrush x:Key="SgNeutralActionHoverBrush" Color="#162D49" />
            <SolidColorBrush x:Key="SgNeutralActionPressedBrush" Color="#0C1B2D" />
            <SolidColorBrush x:Key="SgNeutralActionBorderBrush" Color="#31516F" />
            <SolidColorBrush x:Key="SgNeutralActionTextBrush" Color="#F4F7FA" />
            <SolidColorBrush x:Key="SgSubtleTextBrush" Color="#718198" />
            <SolidColorBrush x:Key="SgSecondaryActionBrush" Color="#162438" />
            <SolidColorBrush x:Key="SgSecondaryActionHoverBrush" Color="#17263A" />
            <SolidColorBrush x:Key="SgSecondaryActionPressedBrush" Color="#20324A" />
            <SolidColorBrush x:Key="SgSecondaryActionBorderBrush" Color="#34506B" />
            <SolidColorBrush x:Key="SgSecondaryActionTextBrush" Color="#F4F7FA" />
            <SolidColorBrush x:Key="SgIconButtonBrush" Color="#162438" />
            <SolidColorBrush x:Key="SgIconButtonHoverBrush" Color="#20324A" />
            <SolidColorBrush x:Key="SgIconButtonPressedBrush" Color="#263B56" />
            <SolidColorBrush x:Key="SgDisabledBrush" Color="#0F1A27" />
            <SolidColorBrush x:Key="SgDisabledBorderBrush" Color="#24364B" />
            <SolidColorBrush x:Key="SgDisabledTextBrush" Color="#65758A" />
            <SolidColorBrush x:Key="SgTileBrush" Color="#0F1A27" />
            <SolidColorBrush x:Key="SgTileHoverBrush" Color="#17263A" />
            <SolidColorBrush x:Key="SgTileActiveBrush" Color="#182A3E" />
            <SolidColorBrush x:Key="SgTileIconBrush" Color="#162438" />
            <SolidColorBrush x:Key="SgTrafficCardBrush" Color="#0F1A27" />
            <SolidColorBrush x:Key="SgTrafficSectionBrush" Color="#162438" />
            <SolidColorBrush x:Key="SgDangerSoftBrush" Color="#3B1E2A" />
            <SolidColorBrush x:Key="SgPrimaryActionBorderBrush" Color="#2A7A5C" />
            <SolidColorBrush x:Key="SgPrimaryActionTextBrush" Color="#EDF8F4" />
            <LinearGradientBrush x:Key="SgPrimaryActionBrush" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="#163B36" />
                <GradientStop Offset="1" Color="#102E2A" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="SgPrimaryActionHoverBrush" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="#1B4B43" />
                <GradientStop Offset="1" Color="#143C36" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="SgPrimaryActionPressedBrush" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="#102E2A" />
                <GradientStop Offset="1" Color="#0C2421" />
            </LinearGradientBrush>


            <!-- Base template for SG Client action buttons. It keeps disabled, hover and pressed states inside the active SG palette and prevents the white WPF fallback. -->
            <Style x:Key="SgWindowButtonBase" TargetType="{x:Type Button}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border
                                x:Name="SgButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True"
                                    TextElement.FontFamily="{TemplateBinding FontFamily}"
                                    TextElement.FontSize="{TemplateBinding FontSize}"
                                    TextElement.FontWeight="{TemplateBinding FontWeight}"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SgButtonBorder" Property="Opacity" Value="0.96" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="SgButtonBorder" Property="Opacity" Value="0.88" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="SgButtonBorder" Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource SgDisabledBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SgDisabledTextBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SgDisabledBorderBrush}" />
                                    <Setter TargetName="SgButtonBorder" Property="Opacity" Value="1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- One themed fallback for every ordinary button. Explicit semantic styles (primary, warning, danger) remain in control. -->
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SgWindowButtonBase}">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="14,5" />
                <Setter Property="Background" Value="{DynamicResource SgSecondaryActionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgSecondaryActionTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgSecondaryActionBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SgSecondaryActionHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SgSecondaryActionPressedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Unified dark SG tooltips: no white system popups over the main window. -->
            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="HasDropShadow" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToolTip}">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SgSnackbar" BasedOn="{StaticResource {x:Type materialDesign:Snackbar}}" TargetType="{x:Type materialDesign:Snackbar}">
                <Setter Property="Background" Value="{DynamicResource SgSurfaceRaisedBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgAccentBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="MaxWidth" Value="620" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <system:Double x:Key="MenuItemHeight">32</system:Double>
            <system:Double x:Key="StdFontSize">13</system:Double>
            <system:Double x:Key="StdFontSize1">14</system:Double>
            <system:Double x:Key="StdFontSize-1">11</system:Double>

            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <Thickness
                x:Key="Margin4"
                Bottom="4"
                Left="4"
                Right="4"
                Top="4" />
            <Thickness
                x:Key="Margin8"
                Bottom="8"
                Left="8"
                Right="8"
                Top="8" />
            <Thickness
                x:Key="OutlinedTextBoxDefaultPadding"
                Bottom="8"
                Left="8"
                Right="8"
                Top="8" />
            <Thickness
                x:Key="MarginLeftRight4"
                Bottom="0"
                Left="4"
                Right="4"
                Top="0" />
            <Thickness
                x:Key="MarginLeftRight8"
                Bottom="0"
                Left="8"
                Right="8"
                Top="0" />
            <Thickness
                x:Key="MarginLeft8"
                Bottom="0"
                Left="8"
                Right="0"
                Top="0" />
            <Thickness
                x:Key="MarginRight8"
                Bottom="0"
                Left="0"
                Right="8"
                Top="0" />
            <Style
                x:Key="ModuleTitle"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize1}" />
            </Style>
            <Style
                x:Key="ToolbarTextBlock"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="StatusbarItem"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style TargetType="{x:Type TextElement}">
                <Setter Property="FontWeight" Value="Regular" />
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontWeight" Value="Regular" />
            </Style>
            <Style x:Key="lvItemSelected" TargetType="{x:Type ListViewItem}">
                <Setter Property="Margin" Value="2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <materialDesign:Card Name="_Card" SnapsToDevicePixels="true">
                                <ContentPresenter />
                            </materialDesign:Card>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="true">
                                    <Setter TargetName="_Card" Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GridViewColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
                <Setter Property="Height" Value="30" />
            </Style>
            <Style
                x:Key="ListItemCheckBox"
                BasedOn="{StaticResource MaterialDesignUserForegroundCheckBox}"
                TargetType="{x:Type CheckBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="DefButton"
                BasedOn="{StaticResource MaterialDesignRaisedButton}"
                TargetType="{x:Type ButtonBase}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="DefContextMenu"
                BasedOn="{StaticResource MaterialDesignContextMenu}"
                TargetType="{x:Type ContextMenu}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
                <Setter Property="Background" Value="{DynamicResource SgSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderStrongBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style
                x:Key="ToolbarMenu"
                BasedOn="{StaticResource MaterialDesignMenu}"
                TargetType="{x:Type Menu}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
            </Style>

            <Style
                x:Key="DefComboBox"
                BasedOn="{StaticResource MaterialDesignComboBox}"
                TargetType="{x:Type ComboBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            </Style>
            <Style
                x:Key="DefDataGrid"
                BasedOn="{StaticResource MaterialDesignDataGrid}"
                TargetType="{x:Type DataGrid}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="Background" Value="{DynamicResource SgSurfaceSoftBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
                <Setter Property="RowBackground" Value="{DynamicResource SgSurfaceSoftBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource SgSurfaceBrush}" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SgBorderBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource SgBorderBrush}" />
            </Style>
            <Style
                x:Key="DefTextBox"
                BasedOn="{StaticResource MaterialDesignTextBox}"
                TargetType="{x:Type TextBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
                <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}" />
            </Style>
            <Style
                x:Key="MyOutlinedTextBox"
                BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
                TargetType="{x:Type TextBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="Padding" Value="{StaticResource OutlinedTextBoxDefaultPadding}" />
                <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
                <Setter Property="CaretBrush" Value="{DynamicResource SgAccentBrush}" />
            </Style>
            <Style
                x:Key="MyGroupBox"
                BasedOn="{StaticResource MaterialDesignGroupBox}"
                TargetType="{x:Type GroupBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="MyChipListBoxItem"
                BasedOn="{StaticResource MaterialDesignChoiceChipPrimaryOutlineListBoxItem}"
                TargetType="{x:Type ListBoxItem}">
                <Setter Property="Margin" Value="-2,0" />
            </Style>
            <Style
                x:Key="MyOutlinedTextComboBox"
                BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
                TargetType="{x:Type ComboBox}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="Padding" Value="{StaticResource OutlinedTextBoxDefaultPadding}" />
                <Setter Property="Background" Value="{DynamicResource SgInputBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SgBorderBrush}" />
            </Style>
            <Style x:Key="ListItemChip" TargetType="{x:Type materialDesign:Chip}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="ListItemTitle"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="ListItemSubTitle"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
            </Style>
            <Style
                x:Key="ListItemSubTitle2"
                BasedOn="{StaticResource MaterialDesignTextBlock}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize-1}" />
            </Style>

            <Style
                x:Key="WindowGlobal"
                BasedOn="{StaticResource {x:Type Window}}"
                TargetType="{x:Type Window}">
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
                <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource SgBackgroundBrush}" />
                <Setter Property="TextElement.FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
                <Setter Property="FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
                <Setter Property="ResizeMode" Value="CanResize" />
            </Style>
            <Style
                x:Key="ViewGlobal"
                BasedOn="{StaticResource {x:Type UserControl}}"
                TargetType="{x:Type UserControl}">
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
                <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SgTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource SgBackgroundBrush}" />
                <Setter Property="TextElement.FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
                <Setter Property="FontFamily" Value="{x:Static conv:MaterialDesignFonts.MyFont}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
